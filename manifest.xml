<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <Id>8f2c8a57-0d7e-4ef2-a643-112233445566</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Stiftung Ambulantes Kinderhospiz</ProviderName>
  <DefaultLocale>de-DE</DefaultLocale>
  <DisplayName DefaultValue="Word AutoFill Add-In"/>
  <Description DefaultValue="Füllt Benutzerdaten automatisch in Word-Vorlagen ein."/>
  <IconUrl DefaultValue="https://AnnaAKM.github.io/word-addin-host/icon.png"/>
  <HighResolutionIconUrl DefaultValue="https://AnnaAKM.github.io/word-addin-host/icon.png"/>
  <SupportUrl DefaultValue="https://AnnaAKM.github.io"/>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <Requirements>
    <Sets>
      <!-- ✅ MinVersion gehört auf <Set>, nicht auf <Sets> -->
      <Set Name="WordApi" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://AnnaAKM.github.io/word-addin-host/index.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- ✅ VersionOverrides direkt in <OfficeApp>, kein <ExtensionPoints>-Wrapper -->
  <ov:VersionOverrides xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                       xsi:type="ov:VersionOverridesV1_0">
    <ov:Hosts>
      <ov:Host xsi:type="ov:Document">
        <ov:DesktopFormFactor>

          <!-- ✅ FunctionFile ist Pflicht, wenn du Event-Handler verwendest -->
          <ov:FunctionFile resid="functionFileUrl"/>

          <ov:ExtensionPoint xsi:type="ov:Events">
            <ov:Event Type="DocumentOpened" FunctionExecution="asynchronous"
                      FunctionName="onDocumentOpen"/>
          </ov:ExtensionPoint>

        </ov:DesktopFormFactor>
      </ov:Host>
    </ov:Hosts>

    <ov:Resources>
      <ov:Images>
        <ov:Image id="icon"
          DefaultValue="https://AnnaAKM.github.io/word-addin-host/icon.png"/>
      </ov:Images>
      <ov:Urls>
        <ov:Url id="homeUrl"
          DefaultValue="https://AnnaAKM.github.io/word-addin-host/index.html"/>
        <!-- ✅ Separate URL für die Funktionsdatei -->
        <ov:Url id="functionFileUrl"
          DefaultValue="https://AnnaAKM.github.io/word-addin-host/functions.js"/>
      </ov:Urls>
      <ov:ShortStrings>
        <ov:String id="displayName" DefaultValue="Word AutoFill Add-In"/>
      </ov:ShortStrings>
      <ov:LongStrings>
        <ov:String id="description"
          DefaultValue="Füllt Benutzerdaten automatisch in Word-Vorlagen ein."/>
      </ov:LongStrings>
    </ov:Resources>
  </ov:VersionOverrides>

</OfficeApp>